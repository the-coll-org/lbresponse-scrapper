# Power BI embed URL (optional — defaults to Lebanon response dashboard)
# POWERBI_EMBED_URL=https://app.powerbi.com/view?r=...

# Firebase Realtime Database URL (required for Firebase storage)
FIREBASE_DB_URL=https://YOUR-PROJECT-default-rtdb.firebaseio.com

# Path to Firebase service account JSON key
# Local: path relative to project root
# Docker: /app/firebase-cred.json (mounted via volume below)
FIREBASE_CRED_PATH=./your-firebase-credentials.json

# Host path to Firebase credentials file (used for Docker volume mount)
FIREBASE_CRED_FILE=./your-firebase-credentials.json

# Schedule interval in hours
SCHEDULE_INTERVAL_HOURS=6

# Unbuffered Python output (for Docker logs)
PYTHONUNBUFFERED=1
